{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile with role and wallet",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "walletBalance": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "verificationStatus": { "type": "string", "enum": ["none", "pending", "verified", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "walletBalance", "createdAt", "updatedAt"]
    },
    "verification": {
      "title": "Verification Request",
      "description": "User request for identity verification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "idFrontUrl": { "type": "string" },
        "idBackUrl": { "type": "string" },
        "selfieUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "adminComment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "idFrontUrl", "status", "createdAt", "updatedAt"]
    },
    "category": {
      "title": "Category",
      "description": "Category for grouping services",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "isActive", "createdAt", "updatedAt"]
    },
    "paymentMethod": {
      "title": "Payment Method",
      "description": "Admin defined payment methods for users to top up",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "qrCodeUrl": { "type": "string" },
        "note": { "type": "string" },
        "icon": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "isActive", "createdAt", "updatedAt"]
    },
    "deposit": {
      "title": "Deposit",
      "description": "User request to top up wallet balance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethodId": { "type": "string" },
        "proofImageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "adminComment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status", "createdAt", "updatedAt"]
    },
    "service": {
      "title": "Service",
      "description": "Available financial service/product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "price": { "type": "number" },
        "dynamicPrice": { "type": "boolean" },
        "iconType": { "type": "string" },
        "iconBgClass": { "type": "string" },
        "iconTextClass": { "type": "string" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "password", "number"] },
              "required": { "type": "boolean" }
            }
          }
        },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "company", "isActive", "createdAt", "updatedAt"]
    },
    "saved_service": {
      "title": "Saved Service",
      "description": "User's saved connection to a service for quick access",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "customName": { "type": "string" },
        "fieldsData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "createdAt", "updatedAt"]
    },
    "transaction": {
      "title": "Transaction",
      "description": "A payment/recharge order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "fieldsData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "amount", "status", "createdAt", "updatedAt"]
    },
    "notification": {
      "title": "Notification",
      "description": "Alert or update for the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/user" },
      "description": "User profiles"
    },
    "/services/{serviceId}": {
      "schema": { "$ref": "#/entities/service" },
      "description": "List of available services managed by admins"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/transaction" },
      "description": "Records of payment transactions"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/notification" },
      "description": "User notifications"
    },
    "/verifications/{verificationId}": {
      "schema": { "$ref": "#/entities/verification" },
      "description": "Identity verification requests"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/category" },
      "description": "Service categories"
    },
    "/savedServices/{savedServiceId}": {
      "schema": { "$ref": "#/entities/saved_service" },
      "description": "Quick access services saved by user"
    },
    "/paymentMethods/{paymentMethodId}": {
      "schema": { "$ref": "#/entities/paymentMethod" },
      "description": "Available payment methods"
    },
    "/deposits/{depositId}": {
      "schema": { "$ref": "#/entities/deposit" },
      "description": "Wallet top-up requests"
    }
  }
}
