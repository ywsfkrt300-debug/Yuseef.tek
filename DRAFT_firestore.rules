rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // الدوال المساعدة (Helper Functions)
    // ============================================
    
    // هل المستخدم مسجل دخوله؟
    function isSignedIn() {
      return request.auth != null;
    }
    
    // هل هو صاحب البيانات؟
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // هل هو مشرف؟ (طرق متعددة للمرونة)
    function isAdmin() {
      return isSignedIn() && (
        // الطريقة 1: البريد الإلكتروني الثابت
        request.auth.token.email == 'yuseef.syrai098@gmail.com' ||
        request.auth.token.email == 'ywsfkrt300@gmail.com' ||
        // الطريقة 2: جدول المشرفين المنفصل
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        // الطريقة 3: حقل role في ملف المستخدم
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    // هل هو مشرف فائق (Super Admin)؟
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'yuseef.syrai098@gmail.com' ||
        request.auth.token.email == 'ywsfkrt300@gmail.com'
      );
    }
    
    // الحقول المسموح للمستخدم العادي تحديثها
    function allowedUserFields() {
      return ['displayName', 'phoneNumber', 'birthDate', 'governorate', 'updatedAt'];
    }
    
    // الحقول المحظورة
    function blockedFields() {
      return ['role', 'walletBalance', 'createdAt', 'email'];
    }
    
    function incoming() {
      return request.resource.data;
    }

    // ============================================
    // القواعد الأساسية
    // ============================================
    
    match /{document=**} {
      allow read, write: if false;
    }
    
    // ============================================
    // جدول المستخدمين (Users)
    // ============================================
    match /users/{userId} {
      // قراءة: صاحب الحساب أو مشرف
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      // قائمة المستخدمين: المشرف فقط
      allow list: if isAdmin();
      
      // إنشاء حساب جديد: فقط المستخدم نفسه
      allow create: if isOwner(userId) && 
                     incoming().role == 'user' &&
                     incoming().walletBalance == 0;
      
      // تحديث: تحكم دقيق حسب الصلاحية
      allow update: if isSignedIn() && (
        // حالة 1: المستخدم يعدل بياناته (بدون صلاحيات أو رصيد)
        (isOwner(userId) && 
         !incoming().diff(resource.data).affectedKeys().hasAny(['role', 'walletBalance', 'createdAt', 'email']) &&
         incoming().updatedAt == request.time) ||
        // حالة 2: المشرف يعدل
        isAdmin() ||
        // حالة 3: السوبر مشرف يعدل أي شيء
        isSuperAdmin()
      );
      
      // حذف: المشرف فقط
      allow delete: if isAdmin();
    }
    
    // ============================================
    // جدول المشرفين (Admins)
    // ============================================
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }
    
    // ============================================
    // جدول الخدمات (Services)
    // ============================================
    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // ============================================
    // جدول الشركات (Companies)
    // ============================================
    match /companies/{companyId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ============================================
    // جدول العمليات المالية (Transactions)
    // ============================================
    match /transactions/{txId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      
      allow create: if isSignedIn() && 
                     incoming().userId == request.auth.uid;
      
      allow update: if isAdmin();
      allow delete: if false;
    }
    
    // ============================================
    // جدول الإشعارات (Notifications)
    // ============================================
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
